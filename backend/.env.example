# stock-advisor — environment configuration
#
# Copy this file to `.env` and fill in values as you collect them.
# `.env` is gitignored. The GitHub PAT is intentionally NOT in this file —
# it lives at ~/.config/stock-advisor/github_token and is read at runtime.

# ---------- runtime ----------
APP_ENV=development
LOG_LEVEL=INFO
SQLITE_PATH=./data/stock-advisor.db
TIMEZONE=Europe/Vilnius
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=0

# ---------- data publishing ----------
# Local clone path of the data repo (this app pushes commits here).
DATA_REPO_PATH=../../stock-advisor-data
DATA_REPO_REMOTE=origin
DATA_REPO_BRANCH=main
GITHUB_TOKEN_FILE=~/.config/stock-advisor/github_token
GITHUB_OWNER=karoliszem93
GITHUB_DATA_REPO=stock-advisor-data
GIT_AUTHOR_NAME=Stock Advisor Bot
GIT_AUTHOR_EMAIL=karolis.zem93@gmail.com

# ---------- LLM ----------
# Choose: "openrouter" (one key, many models — recommended),
# "gemini", "openai", "anthropic", or "ollama" (local).
LLM_PROVIDER=openrouter

# OpenRouter — single key, ~50+ models, OpenAI-compatible API.
# Get a key at https://openrouter.ai/keys.
# Model syntax: <provider>/<model> (see openrouter.ai/models).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-pro

# Gemini — FREE tier from Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI — get a key at https://platform.openai.com/api-keys (requires billing).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude API — get a key at https://console.anthropic.com/settings/keys.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Local Ollama (used when LLM_PROVIDER=ollama).
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_TIMEOUT_SECONDS=180

# ---------- market data providers ----------
# yfinance: no key needed
ALPHAVANTAGE_API_KEY=
FINNHUB_API_KEY=
FMP_API_KEY=
SIMFIN_API_KEY=
NEWSAPI_API_KEY=
FRED_API_KEY=

# Reddit — create a "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=stock-advisor/0.1 by karoliszem93

# SEC EDGAR — no key, but they require a User-Agent identifying you.
SEC_EDGAR_USER_AGENT=Karolis Zemaitis karolis.zem93@gmail.com

# ---------- analysis defaults ----------
BASE_CURRENCY=EUR
LT_CAPITAL_GAINS_RATE=0.15
LT_DIVIDEND_TAX_RATE=0.15
LT_ANNUAL_CG_EXEMPTION_EUR=500
